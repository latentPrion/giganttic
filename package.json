{
  "name": "giganttic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "backend:build": "tsc -p tsconfig.backend.json",
    "backend:start": "node dist/backend/main.js",
    "db:generate": "node db/generate-ddl.mjs",
    "db:generate:active": "node db/generate-ddl.mjs",
    "db:generate:migration": "node db/generate-migration.mjs",
    "db:generate:snapshot": "node db/generate-schema-snapshot.mjs",
    "db:prepare": "node db/prepare.mjs",
    "db:test-data": "node db/test-data.mjs",
    "db:migrate": "node db/migrate.mjs",
    "db:create": "node db/create-db.mjs",
    "charts:development-planner": "node scripts/generate-development-planner-gantt.mjs",
    "dev": "node scripts/dev-launcher.mjs",
    "dev:lan": "node scripts/dev-launcher.mjs --lan",
    "frontend:build": "vite build --config frontend/vite.config.ts",
    "frontend:dev": "vite --config frontend/vite.config.ts",
    "frontend:dev:lan": "vite --host 0.0.0.0 --config frontend/vite.config.ts",
    "frontend:preview": "vite preview --config frontend/vite.config.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.frontend.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/platform-fastify": "^10.4.20",
    "@nestjs/testing": "^10.4.20",
    "@types/supertest": "^7.2.0",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.44.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.30.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.2.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^0.31.4",
    "drizzle-zod": "^0.8.3",
    "jsdom": "^24.1.3",
    "sql.js": "^1.13.0",
    "typescript": "^5.9.2",
    "vite": "^5.4.19",
    "vitest": "^2.1.8"
  }
}
